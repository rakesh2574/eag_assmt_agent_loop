# ---------------------------------------------------------------------------
# EAG V3 Session 6 — ONE .env for BOTH the gateway and the agent.
#   cp .env.example .env      (DON'T overwrite an existing .env that already
#                              has your provider keys — merge instead)
#
# Why one file: the gateway loads `ROOT.parent/.env` (see llm_gatewayV3/main.py),
# and llm_gatewayV3/ lives INSIDE this folder, so `../.env` == this same .env.
# ---------------------------------------------------------------------------

# === PROVIDER KEYS — read by the GATEWAY (llm_gatewayV3) ====================
# Perception and Memory are pinned to Gemini, so GEMINI_API_KEY is REQUIRED.
# The others are optional; the gateway uses whatever subset is present.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional extra workers / routers (see llm_gatewayV3/README.md for the full list)
GROQ_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=
OPEN_ROUTER_API_KEY=
GITHUB_ACCESS_TOKEN=

# === AGENT-LOOP VARS — read by agent6.py / mcp_server.py ====================
# Tavily is the PRIMARY web_search backend in mcp_server.py. Without it,
# web_search falls back to DuckDuckGo (no key, lower quality). Tests B and D
# work better with Tavily. Free key: https://app.tavily.com
TAVILY_API_KEY=

# Where the gateway listens (default is fine).
LLM_GATEWAY_V3_URL=http://localhost:8101

# Which worker the agent pins for Perception + Memory (and Decision's fallback).
# Default "g" = Gemini. Set to "gh" to use GitHub Models' openai/gpt-4.1-mini.
# (Any gateway shortcut works: g, gh, gr, c, n, or, oll.)
# AGENT_PROVIDER=gh

# Attachment window fed to Decision. Default 48000 suits long-context workers.
# GitHub Models' gpt-4.1-mini caps INPUT at 8K tokens, so when AGENT_PROVIDER=gh
# set this to ~18000 chars so the prompt stays under the cap.
# MAX_ATTACH_CHARS=18000

# Optional: override the agent loop's iteration budget (default 12).
# MAX_ITERATIONS=12
